rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Fields:
    //   - amount: number (required)
    //   - date: timestamp (required)
    //   - description: string (required, < 500 chars)
    //   - type: string (required, 'income' or 'expense')
    //   - category: string (required)
    //   - quantityInKg: number (optional)
    //   - ratePerKg: number (optional)
    //   - uid: string (required, matches owner)
    //   - createdAt: timestamp (required)
    //
    // Collection: categories
    // Fields:
    //   - name: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      // Use both email and UID for maximum robustness
      return isAuthenticated() && 
        (request.auth.token.email == "admin@mydomain.com" || 
         request.auth.token.email == "mailtoempee@gmail.com" ||
         request.auth.uid == "TASLPb3StofNJV92jCOHuJjulyg1");
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidTransaction(data) {
      return hasRequiredFields(['amount', 'date', 'description', 'type', 'category', 'uid']) &&
             data.amount is number &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.uid is string;
    }

    function isValidCategory(data) {
      // Simplified validation to ensure it's not the cause of "insufficient permissions"
      return hasRequiredFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{transactionId} {
      // All authenticated users can read transactions
      allow read: if isAuthenticated();
      
      // Only admins can create, update or delete transactions
      allow create, update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      // All authenticated users can read categories
      allow read: if isAuthenticated();
      
      // Only admins can create, update or delete categories
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
